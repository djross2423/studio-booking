# Copy to .env and fill in. Never commit the real .env.

# Neon Postgres — use the POOLED endpoint (host contains "-pooler") for serverless.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Google Calendar + Sheets (OAuth). The refresh token must include the
# spreadsheets scope — add it in scripts/google-auth.js and re-run.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=
GOOGLE_REFRESH_TOKEN=
# Spreadsheet that the finance ledger appends to (a tab named "Ledger").
GOOGLE_SHEETS_ID=

# Finance chat assistant (Google Gemini — free tier via Google AI Studio).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override the model (defaults to gemini-2.5-flash)
GEMINI_MODEL=
# Optional: if set, /api/chat requires an x-chat-secret header matching this
CHAT_SHARED_SECRET=
