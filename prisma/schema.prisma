generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id          Int              @id @default(autoincrement())
  name        String
  phone       String?
  notes       String?
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  bookings    Booking[]
  enrolments  BatchEnrolment[]
  absences    Absence[]
  enrollments Enrollment[]
}

model Faculty {
  id         Int                 @id @default(autoincrement())
  name       String
  phone      String?
  active     Boolean             @default(true)
  createdAt  DateTime            @default(now())
  batches    Batch[]
  attendance FacultyAttendance[]
}

model Course {
  id              Int      @id @default(autoincrement())
  name            String
  totalSessions   Int
  sessionDuration Float
  fee             Float
  color           String   @default("#6C3CE1")
  description     String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  batches     Batch[]
  enrollments Enrollment[]
}

model Batch {
  id          Int              @id @default(autoincrement())
  name        String
  room        String
  startTime   String
  duration    Int
  repeatDays  String
  startDate   String
  endDate     String
  color       String           @default("#6C3CE1")
  status      String           @default("active")
  facultyId   Int?
  faculty     Faculty?         @relation(fields: [facultyId], references: [id])
  courseId    Int?
  course      Course?          @relation(fields: [courseId], references: [id])
  createdAt   DateTime         @default(now())
  bookings    Booking[]
  enrolments  BatchEnrolment[]

  @@index([status])
  @@index([courseId])
  @@index([facultyId])
}

model BatchEnrolment {
  id       Int    @id @default(autoincrement())
  batchId  Int
  clientId Int
  batch    Batch  @relation(fields: [batchId], references: [id])
  client   Client @relation(fields: [clientId], references: [id])

  @@index([batchId])
  @@index([clientId])
}

model Booking {
  id                Int                 @id @default(autoincrement())
  clientId          Int?
  client            Client?             @relation(fields: [clientId], references: [id])
  room              String
  startTime         DateTime
  endTime           DateTime
  sessionType       String?
  status            String              @default("confirmed")
  notes             String?
  googleEventId     String?
  batchId           Int?
  batch             Batch?              @relation(fields: [batchId], references: [id])
  createdAt         DateTime            @default(now())
  absences          Absence[]
  facultyAttendance FacultyAttendance[]

  @@index([room, startTime, endTime])
  @@index([startTime])
  @@index([status])
  @@index([clientId])
  @@index([batchId])
}

model Absence {
  id        Int      @id @default(autoincrement())
  clientId  Int
  bookingId Int
  client    Client   @relation(fields: [clientId], references: [id])
  booking   Booking  @relation(fields: [bookingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([clientId, bookingId])
  @@index([bookingId])
}

model FacultyAttendance {
  id        Int      @id @default(autoincrement())
  facultyId Int
  bookingId Int
  present   Boolean  @default(true)
  faculty   Faculty  @relation(fields: [facultyId], references: [id])
  booking   Booking  @relation(fields: [bookingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([facultyId, bookingId])
  @@index([bookingId])
}

model Enrollment {
  id Int @id @default(autoincrement())

  clientId Int
  courseId Int

  totalFee Float
  discount Float @default(0)

  enrolledOn DateTime @default(now())

  status String @default("active")

  client Client @relation(fields: [clientId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  payments FeePayment[]

  @@index([clientId])
  @@index([courseId])
  @@index([status])
}

model FeePayment {
  id Int @id @default(autoincrement())

  enrollmentId Int

  amount Float

  paymentDate DateTime @default(now())

  paymentMethod String

  reference String?

  notes String?

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])

  @@index([enrollmentId])
}
